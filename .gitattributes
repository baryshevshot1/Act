# Auto detect text files and perform LF normalization on commit
* text=auto eol=lf

# Force LF for source files (cross-platform consistency)
*.py        text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.sh        text eol=lf
*.sql       text eol=lf
Makefile    text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf

# Binary files (no diff, no LF conversion)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary

# Figma / design exports
*.fig       binary
*.sketch    binary
