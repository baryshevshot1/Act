# Act — Environment Variables
# ---------------------------
# Copy to .env.local (gitignored) and fill values for local dev.
# For production — values живут в Yandex Lockbox / Coolify secrets.
# NEVER commit .env / .env.local — только этот .env.example.
# Источники: CLAUDE.md строки 47-69 (стек); ADR-014 (PII encryption); ADR-016 (Outbox).

# === Django core ===
DJANGO_SETTINGS_MODULE=act.settings.dev
SECRET_KEY=__CHANGE_ME__use_python_-c_"import_secrets;print(secrets.token_urlsafe(50))"
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Europe/Moscow

# === PostgreSQL 17 (Yandex Managed в production) ===
# NON-NEGOTIABLE #11: миграции ВСЕГДА через прямой PG, минуя PgBouncer.
# Local dev: docker-compose.yml поднимает PG напрямую (без bouncer).
DATABASE_URL=postgres://act_app:act_app_pass@localhost:5432/act_dev
# Отдельный URL для миграций — bypass PgBouncer в production.
DATABASE_URL_DIRECT=postgres://act_app:act_app_pass@localhost:5432/act_dev
# Отдельная роль с BYPASSRLS для Django Admin (RLS Operational Constraints).
DATABASE_URL_ADMIN=postgres://act_admin:act_admin_pass@localhost:5432/act_dev

# === PII Encryption (ADR-014) ===
# Yandex Lockbox key ID в production; локально — env key.
YANDEX_LOCKBOX_KEY_ID=__yandex_lockbox_key_id_in_production__

# HMAC secret для exact-match lookup по encrypted полям.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(64))"
PII_HMAC_SECRET=__CHANGE_ME__64_chars_secrets.token_urlsafe(64)__

# Fernet encryption key (apps.core.crypto.EncryptedField, ADR-014 revised).
# Single key (dev/test): PII_ENCRYPTION_KEY=<base64-fernet-key>
# Сгенерировать: python -c "from apps.core.crypto import generate_key; print(generate_key())"
PII_ENCRYPTION_KEY=__base64_fernet_key_44_chars__

# Production: PII_ENCRYPTION_KEYRING — comma-separated newest-first для rotation
# через MultiFernet. Загружается из Yandex Lockbox в apps/core/lockbox.py (W1 sprint).
# PII_ENCRYPTION_KEYRING=<new_key>,<previous_key>,<2-years-ago_key>

# === Procrastinate (Background jobs, ADR-006) ===
PROCRASTINATE_DATABASE_URL=${DATABASE_URL}
PROCRASTINATE_APP=act.procrastinate_app:app

# === Auth (django-allauth — NON-NEGOTIABLE #3: no Clerk/Auth0/Supabase) ===
# Telegram OIDC primary [F: CLAUDE.md NON-NEGOTIABLE #9: ст. 12 152-ФЗ]
# ВНИМАНИЕ: использование требует ConsentRecord(purpose='cross_border_transfer').
TELEGRAM_BOT_TOKEN=__from_BotFather__
TELEGRAM_BOT_USERNAME=act_bot
# Gateway для phone OTP — только при наличии ст. 12 consent.
TELEGRAM_GATEWAY_TOKEN=__test_via_TON_$5-10__

# VK ID secondary
VK_ID_APP_ID=__from_id.vk.com_about_business__
VK_ID_CLIENT_SECRET=__from_id.vk.com__

# Yandex ID secondary
YANDEX_ID_CLIENT_ID=__from_oauth.yandex.ru__
YANDEX_ID_CLIENT_SECRET=__from_oauth.yandex.ru__

# === Email ESP (V1.2 секция J1: UniSender ИЛИ SendPulse) ===
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=__unisender_or_sendpulse__
EMAIL_HOST_USER=__esp_login__
EMAIL_HOST_PASSWORD=__esp_password__
EMAIL_PORT=465
EMAIL_USE_SSL=true
DEFAULT_FROM_EMAIL=no-reply@act.app

# === SMS (V1.1 раздел 3.6: SMS.ru tertiary) ===
SMS_RU_API_ID=__from_sms.ru_after_ИП_registration__

# === Yandex Cloud (ADR-004) ===
YANDEX_OBJECT_STORAGE_BUCKET=act-prod-media
YANDEX_OBJECT_STORAGE_ACCESS_KEY=__from_yandex_cloud_iam__
YANDEX_OBJECT_STORAGE_SECRET_KEY=__from_yandex_cloud_iam__
YANDEX_OBJECT_STORAGE_ENDPOINT=https://storage.yandexcloud.net

# === Analytics + Observability ===
POSTHOG_API_KEY=__self_hosted_posthog__
POSTHOG_HOST=https://posthog.act.app          # self-hosted in РФ
SENTRY_DSN=__self_hosted_sentry_or_glitchtip__

# === Frontend (Next.js 16) ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Feature flags (PostHog) ===
# ADR-008 — per-weight discovery ranking flags
# discovery_ranking_w_rep, discovery_ranking_w_act, ... через PostHog dashboard

# === RKN compliance (NON-NEGOTIABLE #10) ===
# Эти переменные НЕ environment — это записи в БД и docs/, но фиксируем напоминание:
# - Уведомление РКН по ст. 22 (общая обработка ПДн) подано до production: __DATE__
# - Уведомление РКН по ст. 12 (трансграничная в Telegram FZ-LLC) подано: __DATE__
# - Privacy Policy опубликована на /privacy: __DATE__
# - Cookie consent UI implemented: __DATE__
